pipeline {
    agent any
    stages {
        stage('Build Docker Image') {
            steps {
                // Docker 이미지 빌드
                sh 'docker build -t myapp:${BUILD_NUMBER} .'
            }
        }
        stage('Run Docker Container') {
            steps {
                // Docker 컨테이너 실행
                sh 'docker run --name my-container -d myapp:${BUILD_NUMBER} ./hello.py'
            }
        }
        stage('Deploy') {
            steps {
                // 배포
                sh 'docker push localhost:5000/myapp:${BUILD_NUMBER}'
            }
        }
    }
}